{
  "name": "@machinery/assemblers",
  "version": "0.0.1",
  "type": "module",
  "main": "./dist/index.cjs",
  "module": "./dist/index.js",
  "types": "./dist/index.d.ts",
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "import": "./dist/index.js",
      "require": "./dist/index.cjs"
    },
    "./i286/intel": {
      "types": "./dist/i286/intel/index.d.ts",
      "import": "./dist/i286/intel/index.js",
      "require": "./dist/i286/intel/index.cjs"
    },
    "./z80/intel": {
      "types": "./dist/z80/intel/index.d.ts",
      "import": "./dist/z80/intel/index.js",
      "require": "./dist/z80/intel/index.cjs"
    }
  },
  "bin": {
    "machinery-asm": "./dist/cli.js",
    "machinery-generate": "./dist/generate.js"
  },
  "scripts": {
    "generate:i286": "npx tsx src/generate.ts -t i286 -s intel -o src/i286/intel",
    "generate:z80": "npx tsx src/generate.ts -t z80 -s intel -o src/z80/intel",
    "generate": "pnpm generate:i286 && pnpm generate:z80",
    "generate:targets": "npx tsx src/generate-targets.ts",
    "build:grammar:i286": "nearleyc src/i286/intel/grammar.ne -o src/i286/intel/grammar.ts",
    "build:grammar:z80": "nearleyc src/z80/intel/grammar.ne -o src/z80/intel/grammar.ts",
    "build:grammar": "pnpm build:grammar:i286 && pnpm build:grammar:z80",
    "build": "pnpm generate:targets && pnpm build:grammar && tsup",
    "test": "jest --passWithNoTests",
    "lint": "eslint src",
    "clean": "rm -rf dist",
    "typecheck": "tsc --noEmit"
  },
  "dependencies": {
    "@machinery/core": "workspace:*",
    "@machinery/processors": "workspace:*",
    "moo": "^0.5.2",
    "nearley": "^2.20.1"
  },
  "devDependencies": {
    "@types/moo": "^0.5.10",
    "@types/nearley": "^2.11.5",
    "@types/node": "^22.15.0"
  },
  "files": [
    "dist"
  ]
}
